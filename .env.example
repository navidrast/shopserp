# ShopSerp Configuration
DATABASE_URL=sqlite+aiosqlite:///./data/shopserp.db
SCRAPE_INTERVAL_MINUTES=360
DEFAULT_COUNTRIES=US,AU
PROXY_URL=
PROXY_ROTATION_ENABLED=false
REQUEST_TIMEOUT=30
MAX_CONCURRENT_SCRAPES=3
ALERT_WEBHOOK_URL=
LOG_LEVEL=INFO

# Search Backend (pick one for reliable results):
# Option 1: Serper.dev API - 2,500 free searches, sign up at https://serper.dev
SERPER_API_KEY=
# Option 2: SerpAPI - 100 free searches/month, sign up at https://serpapi.com
SERPAPI_KEY=
# Option 3: No key = Playwright headless browser (free but needs residential proxy for best results)

# External API authentication (comma-separated name:key pairs)
# API_KEYS=returnpilot:sk-your-secret-key-here
